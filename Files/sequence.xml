<mxfile host="app.diagrams.net">
  <diagram name="CertiLock Sequence Diagram">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ACTORS / LIFELINES -->
        <mxCell id="a1" value="Admin" style="shape=umlLifeline;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="100" y="40" width="100" height="600" as="geometry"/>
        </mxCell>

        <mxCell id="a2" value="System (App)" style="shape=umlLifeline;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="300" y="40" width="120" height="600" as="geometry"/>
        </mxCell>

        <mxCell id="a3" value="Backend" style="shape=umlLifeline;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="500" y="40" width="120" height="600" as="geometry"/>
        </mxCell>

        <mxCell id="a4" value="Blockchain" style="shape=umlLifeline;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="700" y="40" width="120" height="600" as="geometry"/>
        </mxCell>

        <mxCell id="a5" value="Storage" style="shape=umlLifeline;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="900" y="40" width="120" height="600" as="geometry"/>
        </mxCell>

        <mxCell id="a6" value="Verifier" style="shape=umlLifeline;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1100" y="40" width="120" height="600" as="geometry"/>
        </mxCell>

        <!-- ISSUANCE FLOW -->
        <mxCell id="m1" value="Enter Certificate Details" style="endArrow=block;" edge="1" parent="1" source="a1" target="a2">
          <mxGeometry relative="1" as="geometry"><mxPoint x="0" y="100"/></mxGeometry>
        </mxCell>

        <mxCell id="m2" value="Generate SHA-256 Hash" style="endArrow=block;" edge="1" parent="1" source="a2" target="a3">
          <mxGeometry relative="1" as="geometry"><mxPoint x="0" y="150"/></mxGeometry>
        </mxCell>

        <mxCell id="m3" value="Create Digital Signature" style="endArrow=block;" edge="1" parent="1" source="a3" target="a3">
          <mxGeometry relative="1" as="geometry"><mxPoint x="0" y="200"/></mxGeometry>
        </mxCell>

        <mxCell id="m4" value="Store Hash on Blockchain" style="endArrow=block;" edge="1" parent="1" source="a3" target="a4">
          <mxGeometry relative="1" as="geometry"><mxPoint x="0" y="250"/></mxGeometry>
        </mxCell>

        <mxCell id="m5" value="Store Certificate" style="endArrow=block;" edge="1" parent="1" source="a3" target="a5">
          <mxGeometry relative="1" as="geometry"><mxPoint x="0" y="300"/></mxGeometry>
        </mxCell>

        <mxCell id="m6" value="Generate QR Code" style="endArrow=block;" edge="1" parent="1" source="a2" target="a1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="0" y="350"/></mxGeometry>
        </mxCell>

        <!-- VERIFICATION FLOW -->
        <mxCell id="m7" value="Scan QR Code" style="endArrow=block;" edge="1" parent="1" source="a6" target="a2">
          <mxGeometry relative="1" as="geometry"><mxPoint x="0" y="400"/></mxGeometry>
        </mxCell>

        <mxCell id="m8" value="Fetch Certificate Data" style="endArrow=block;" edge="1" parent="1" source="a2" target="a3">
          <mxGeometry relative="1" as="geometry"><mxPoint x="0" y="450"/></mxGeometry>
        </mxCell>

        <mxCell id="m9" value="Get Stored Data" style="endArrow=block;" edge="1" parent="1" source="a3" target="a5">
          <mxGeometry relative="1" as="geometry"><mxPoint x="0" y="500"/></mxGeometry>
        </mxCell>

        <mxCell id="m10" value="Recompute Hash" style="endArrow=block;" edge="1" parent="1" source="a3" target="a3">
          <mxGeometry relative="1" as="geometry"><mxPoint x="0" y="550"/></mxGeometry>
        </mxCell>

        <mxCell id="m11" value="Compare with Blockchain" style="endArrow=block;" edge="1" parent="1" source="a3" target="a4">
          <mxGeometry relative="1" as="geometry"><mxPoint x="0" y="600"/></mxGeometry>
        </mxCell>

        <mxCell id="m12" value="Verification Result" style="endArrow=block;" edge="1" parent="1" source="a3" target="a6">
          <mxGeometry relative="1" as="geometry"><mxPoint x="0" y="650"/></mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>